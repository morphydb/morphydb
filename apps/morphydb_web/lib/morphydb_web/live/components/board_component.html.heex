<div class="max-w-screen-sm md:max-w-screen-md p-4">
    <div class="grid grid-cols-8 gap-0">
        <%= for rank <- 1..8 do %>
            <%= for file <- 1..8 do %>
                <.live_component module={TileComponent} id={rank * 8 + file} rank={rank} file={file} />
            <% end %>
        <% end %>
    </div>
</div>
